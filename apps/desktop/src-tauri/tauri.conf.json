{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KM Editor",
  "version": "0.0.2",
  "identifier": "app.kmeditor.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm sprites:ensure && pnpm sidecar:publish && pnpm dev",
    "beforeBuildCommand": "pnpm sprites:ensure && pnpm sidecar:publish && pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KM Editor v0.0.2",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/km-tools-bridge"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
