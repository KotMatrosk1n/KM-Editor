{
  "name": "km-editor",
  "version": "2.0.2",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.5.2"
  },
  "scripts": {
    "dev": "pnpm --filter @km-editor/desktop dev",
    "build": "pnpm --filter @km-editor/desktop build",
    "sidecar:publish": "pnpm --filter @km-editor/desktop sidecar:publish",
    "tauri:dev": "pnpm --filter @km-editor/desktop tauri:dev",
    "tauri:build": "pnpm --filter @km-editor/desktop tauri:build",
    "typecheck": "pnpm --filter @km-editor/desktop typecheck",
    "test": "pnpm --filter @km-editor/desktop test",
    "test:run": "pnpm --filter @km-editor/desktop test:run",
    "test:changed": "node scripts/test-slice.mjs changed",
    "test:changed:print": "node scripts/test-slice.mjs changed --print",
    "test:fast": "node scripts/test-slice.mjs fast",
    "test:full": "node scripts/test-slice.mjs full",
    "test:workflow": "pnpm --filter @km-editor/desktop test:workflow",
    "check": "pnpm run typecheck && pnpm run build && pnpm run test:run",
    "check:fast": "node scripts/test-slice.mjs fast",
    "check:workspace": "node scripts/check-workspace-paths.mjs"
  }
}
